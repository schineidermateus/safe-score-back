APP_ENV=prod
APP_SECRET=change-me-in-runtime
DEFAULT_URI=http://localhost
DATABASE_URL="mysql://safe_score:safe_score@database:3306/safe_score?charset=utf8mb4"
DATABASE_SERVER_VERSION=8.4
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

###> autenticação jwt (produção) ###
# Endpoint público JWKS do (futuro) serviço de autenticação. Apenas chaves públicas são lidas aqui.
JWKS_URI=http://auth.safescore.local/v1/jwks
JWKS_CACHE_TTL=3600
# Claims que o access token recebido precisa satisfazer para ser aceito.
JWT_ISSUER=https://auth.safescore.local
JWT_AUDIENCE=safescore-api
JWT_CLOCK_SKEW=30
###< autenticação jwt (produção) ###
